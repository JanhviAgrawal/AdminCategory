<!DOCTYPE html>
<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Reset Password - AdminCore</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#F7CBCA",
                        "charcoal": "#5D6B6B",
                        "background-gray": "#F1F7F7",
                        "input-border": "#E5E7EB",
                    },
                    fontFamily: {
                        "display": ["Manrope", "sans-serif"]
                    },
                    borderRadius: {
                        "card": "1rem",
                    },
                },
            },
        }
    </script>
    <style type="text/tailwindcss">
        @layer base {
            body {
                font-family: 'Manrope', sans-serif;
            }
            .material-symbols-outlined {
                font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            }
        }
    </style>
</head>

<body class="bg-background-gray text-charcoal min-h-screen flex flex-col font-display">
    <main class="flex-grow flex items-center justify-center px-4 py-12">
        <div
            class="w-full max-w-[440px] bg-white rounded-card shadow-[0_10px_40px_-15px_rgba(0,0,0,0.1)] overflow-hidden">
            <div class="p-8 lg:p-10">
                <div class="flex flex-col items-center mb-8">
                    <div class="p-2.5 bg-primary/10 rounded-xl mb-4">
                        <svg class="size-8 text-charcoal" fill="none" viewBox="0 0 48 48"
                            xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M42.4379 44C42.4379 44 36.0744 33.9038 41.1692 24C46.8624 12.9336 42.2078 4 42.2078 4L7.01134 4C7.01134 4 11.6577 12.932 5.96912 23.9969C0.876273 33.9029 7.27094 44 7.27094 44L42.4379 44Z"
                                fill="currentColor"></path>
                        </svg>
                    </div>
                    <h2 class="text-xl font-bold tracking-tight mb-2">AdminCore</h2>
                    <h1 class="text-2xl font-bold text-charcoal">Reset Your Password</h1>
                </div>

                <!-- FIXED: Added action and method -->
                <form action="/change-new-password" method="POST" class="space-y-5">

                    <!-- New Password -->
                    <div class="space-y-1.5">
                        <label class="block text-sm font-semibold text-charcoal/80 ml-0.5">
                            New Password
                        </label>
                        <div class="relative group">
                            <!-- FIXED: Added name attribute and required -->
                            <input id="new_password" name="new_password"
                                class="w-full h-12 px-4 bg-white border border-input-border rounded-lg focus:ring-2 focus:ring-primary/40 focus:border-primary text-charcoal placeholder:text-gray-400 transition-all outline-none"
                                placeholder="Enter new password" type="password" required />

                            <!-- FIXED: Added onclick for visibility toggle -->
                            <button onclick="togglePassword('new_password', 'icon1')"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-charcoal transition-colors flex items-center"
                                type="button">
                                <span id="icon1" class="material-symbols-outlined text-[20px]">visibility</span>
                            </button>
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="space-y-1.5">
                        <label class="block text-sm font-semibold text-charcoal/80 ml-0.5">
                            Confirm New Password
                        </label>
                        <div class="relative group">
                            <!-- FIXED: Added name attribute and required -->
                            <input id="confirm_password" name="confirm_password"
                                class="w-full h-12 px-4 bg-white border border-input-border rounded-lg focus:ring-2 focus:ring-primary/40 focus:border-primary text-charcoal placeholder:text-gray-400 transition-all outline-none"
                                placeholder="Confirm new password" type="password" required />

                            <!-- FIXED: Added onclick for visibility toggle -->
                            <button onclick="togglePassword('confirm_password', 'icon2')"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-charcoal transition-colors flex items-center"
                                type="button">
                                <span id="icon2" class="material-symbols-outlined text-[20px]">visibility</span>
                            </button>
                        </div>
                    </div>

                    <button
                        class="w-full h-12 bg-primary hover:brightness-95 text-charcoal font-bold text-base rounded-lg shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-2 mt-6"
                        type="submit">
                        <span class="material-symbols-outlined text-[20px]">lock</span>
                        <span>Reset Password</span>
                    </button>
                </form>

                <div class="mt-8 pt-6 border-t border-gray-50 text-center">
                    <!-- FIXED: Link corrected to root "/" -->
                    <a class="inline-flex items-center gap-2 text-sm font-bold text-charcoal/70 hover:text-charcoal transition-colors group"
                        href="/">
                        <span
                            class="material-symbols-outlined text-[18px] group-hover:-translate-x-1 transition-transform">arrow_back</span>
                        Back to Login
                    </a>
                </div>
            </div>
        </div>
    </main>

    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);

            if (input.type === 'password') {
                input.type = 'text';
                icon.innerText = 'visibility_off';
            } else {
                input.type = 'password';
                icon.innerText = 'visibility';
            }
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.all.min.js"></script>
    <script>
        if (<%= locals.flash.success !== "" && locals.flash.success.length > 0 %>) {
            Swal.fire({
                title: "Success!",
                text: "<%= locals.flash.success %>",
                icon: "success"
            });
        }
        if (<%= locals.flash.error !== "" && locals.flash.error.length > 0 %>) {
            Swal.fire({
                title: "Error!",
                text: "<%= locals.flash.error %>",
                icon: "error"
            });
        }
    </script>

    <footer class="py-8 text-center text-gray-400 text-xs uppercase tracking-widest">
        <p>© 2024 AdminCore Management System. All rights reserved.</p>
    </footer>

</body>

</html>
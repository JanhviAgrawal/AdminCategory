<!DOCTYPE html>

<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Forgot Password - Admin Panel</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#f6cdcb",
                        "background-light": "#fafafa",
                        "background-dark": "#1a1f1f",
                        "charcoal": "#1a0f0f",
                    },
                    fontFamily: {
                        "display": ["Manrope", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Manrope', sans-serif;
        }

        .soft-depth {
            box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.05);
        }
    </style>
</head>

<body
    class="bg-background-light dark:bg-background-dark min-h-screen flex flex-col font-display transition-colors duration-300">
    <header
        class="flex items-center justify-between whitespace-nowrap border-b border-solid border-gray-100 dark:border-zinc-800 bg-background-light dark:bg-background-dark px-6 md:px-10 py-3">
        <div class="flex items-center gap-4 text-charcoal dark:text-gray-100">
            <div class="size-6 text-primary flex items-center justify-center">
                <span class="material-symbols-outlined text-3xl">shield_person</span>
            </div>
            <h2 class="text-charcoal dark:text-white text-lg font-bold leading-tight tracking-[-0.015em]">Admin Portal
            </h2>
        </div>
        <button
            class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-4 bg-primary/20 dark:bg-primary/10 text-charcoal dark:text-primary text-sm font-bold leading-normal tracking-[0.015em] hover:bg-primary/30 transition-colors">
            <span class="truncate">Help Center</span>
        </button>
    </header>
    <main class="flex-1 flex items-center justify-center p-6">
        <div
            class="w-full max-w-[440px] bg-white dark:bg-zinc-900 rounded-xl border border-gray-100 dark:border-zinc-800 p-8 soft-depth">
            <div class="mb-2">
                <div class="w-12 h-12 bg-primary/20 rounded-full flex items-center justify-center mb-6 mx-auto">
                    <span class="material-symbols-outlined text-charcoal dark:text-primary">lock_reset</span>
                </div>
                <h1
                    class="text-charcoal dark:text-white tracking-tight text-3xl font-extrabold leading-tight text-center">
                    Forgot Password</h1>
            </div>
            <div class="mb-8">
                <p class="text-zinc-500 dark:text-zinc-400 text-sm font-normal leading-relaxed text-center">
                    Enter your registered email address below. We'll send you a One-Time Password (OTP) to reset your
                    password.
                </p>
            </div>
            <form action="/verify-email" class="space-y-6" method="POST">
                <div class="flex flex-col gap-2">
                    <label class="flex flex-col w-full">
                        <span
                            class="text-charcoal dark:text-zinc-300 text-sm font-semibold leading-normal pb-2 ml-1">Email
                            Address</span>
                        <div class="relative">
                            <span
                                class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-zinc-400 text-xl">mail</span>
                            <!-- FIXED: Added name="email" -->
                            <input name="email"
                                class="form-input flex w-full rounded-lg text-charcoal dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border border-gray-200 dark:border-zinc-700 bg-gray-50 dark:bg-zinc-800 focus:border-primary h-14 placeholder:text-zinc-400 pl-12 pr-4 text-base font-normal transition-all"
                                placeholder="admin@example.com" required type="email" />
                        </div>
                    </label>
                </div>
                <div class="pt-2">
                    <button
                        class="flex w-full cursor-pointer items-center justify-center overflow-hidden rounded-lg h-14 px-5 bg-primary text-charcoal text-base font-bold leading-normal tracking-[0.015em] hover:brightness-95 active:scale-[0.98] transition-all"
                        type="submit">
                        <span class="truncate uppercase tracking-wider">Send OTP</span>
                        <span class="material-symbols-outlined ml-2 text-xl">send</span>
                    </button>
                </div>
            </form>
            <div class="mt-8 pt-6 border-t border-gray-100 dark:border-zinc-800 flex justify-center">
                <!-- FIXED: href changed to "/" to match login route -->
                <a class="flex items-center gap-2 text-zinc-500 dark:text-zinc-400 hover:text-charcoal dark:hover:text-primary text-sm font-semibold transition-colors group"
                    href="/">
                    <span
                        class="material-symbols-outlined text-lg group-hover:-translate-x-1 transition-transform">arrow_back</span>
                    Back to Login
                </a>
            </div>
        </div>
    </main>
    <div class="fixed top-0 left-0 w-full h-full pointer-events-none -z-10 overflow-hidden">
        <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] bg-primary/10 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-5%] left-[-5%] w-[30%] h-[30%] bg-primary/5 rounded-full blur-[100px]"></div>
    </div>
    <footer class="py-6 text-center">
        <p class="text-zinc-400 text-xs font-medium">© 2024 Admin Panel Systems • Security Verified</p>
    </footer>
</body>

</html>
<!DOCTYPE html>
<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Login | Admin Panel</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#F7CBCA",
                        "background-light": "#F1F7F7",
                        "background-dark": "#1a1f1f",
                        "charcoal": "#5D6B6B",
                        "border-muted": "#e5d2d1"
                    },
                    fontFamily: {
                        "display": ["Manrope", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Manrope', sans-serif;
        }

        .login-card-shadow {
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
        }

        .toastify {
            background: #f7cbca !important;
            transform: translate(0px, 0px);
            margin-top: 73px;
            margin-left: 5px;
            width: 20%;
            padding: 5px 8px;
            border-radius: 2px;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark min-h-screen flex flex-col font-display">
    <header
        class="w-full px-6 py-4 flex items-center justify-between bg-white/50 dark:bg-black/10 backdrop-blur-sm fixed top-0 left-0 z-10">
        <div class="flex items-center gap-3">
            <div class="p-2 bg-primary rounded-lg text-charcoal">
                <svg fill="none" height="24" viewBox="0 0 48 48" width="24" xmlns="http://www.w3.org/2000/svg">
                    <path
                        d="M42.4379 44C42.4379 44 36.0744 33.9038 41.1692 24C46.8624 12.9336 42.2078 4 42.2078 4L7.01134 4C7.01134 4 11.6577 12.932 5.96912 23.9969C0.876273 33.9029 7.27094 44 7.27094 44L42.4379 44Z"
                        fill="currentColor"></path>
                </svg>
            </div>
            <span class="text-charcoal dark:text-gray-200 font-bold text-lg tracking-tight">Admin Portal</span>
        </div>
        <div class="flex items-center gap-4">
            <button
                class="text-charcoal/70 dark:text-gray-400 hover:text-charcoal text-sm font-medium transition-colors">
                Support
            </button>
            <button
                class="bg-primary/20 hover:bg-primary/30 text-charcoal px-4 py-2 rounded-lg text-sm font-bold transition-all">
                Help
            </button>
        </div>
    </header>
    <main class="flex-1 flex items-center justify-center px-4 pt-20 pb-12">
        <div class="w-full max-w-[440px]">
            <div
                class="bg-white dark:bg-zinc-900 rounded-xl login-card-shadow border border-gray-100 dark:border-zinc-800 overflow-hidden">
                <div class="p-8 sm:p-10">
                    <div class="flex flex-col items-center mb-10">
                        <div class="size-16 bg-primary/10 rounded-full flex items-center justify-center mb-6">
                            <span class="material-symbols-outlined text-primary text-4xl">fingerprint</span>
                        </div>
                        <h1 class="text-charcoal dark:text-gray-100 text-3xl font-extrabold tracking-tight mb-2">Welcome
                        </h1>
                        <p class="text-charcoal/60 dark:text-gray-400 text-base">Please enter your details to continue
                        </p>
                    </div>
                    <!-- Logic: Form action/method are correct -->
                    <form action="/login" class="space-y-6" method="POST">
                        <div class="space-y-2">
                            <label
                                class="text-charcoal dark:text-gray-300 text-sm font-semibold flex items-center gap-2"
                                for="email">
                                <span class="material-symbols-outlined text-lg">alternate_email</span>
                                Email Address
                            </label>
                            <input
                                class="w-full px-4 py-3.5 bg-gray-50 dark:bg-zinc-800 border border-gray-200 dark:border-zinc-700 rounded-lg text-charcoal dark:text-gray-100 placeholder:text-gray-400 focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all text-base"
                                id="email" name="email" placeholder="name@company.com" required type="email" />
                        </div>
                        <div class="space-y-2">
                            <div class="flex justify-between items-center">
                                <label
                                    class="text-charcoal dark:text-gray-300 text-sm font-semibold flex items-center gap-2"
                                    for="password">
                                    <span class="material-symbols-outlined text-lg">lock</span>
                                    Password
                                </label>
                                <a class="text-primary hover:text-primary/80 text-xs font-bold transition-colors"
                                    href="/verify-email">
                                    Forgot Password?
                                </a>
                            </div>
                            <div class="relative group">
                                <input
                                    class="w-full px-4 py-3.5 bg-gray-50 dark:bg-zinc-800 border border-gray-200 dark:border-zinc-700 rounded-lg text-charcoal dark:text-gray-100 placeholder:text-gray-400 focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all text-base pr-12"
                                    id="password" name="password" placeholder="••••••••" required type="password" />

                                <!-- FIXED: Added id="togglePassword" for logic -->
                                <button id="togglePassword"
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-charcoal dark:hover:text-gray-200 transition-colors"
                                    type="button">
                                    <span class="material-symbols-outlined text-xl" id="toggleIcon">visibility</span>
                                </button>
                            </div>
                        </div>
                        <!-- Logic: submit color changed to charcoal for readability -->
                        <button
                            class="w-full bg-primary hover:bg-opacity-90 text-charcoal font-bold py-4 rounded-lg shadow-sm hover:shadow-md transition-all flex items-center justify-center gap-2 mt-4"
                            type="submit">
                            Login
                            <span class="material-symbols-outlined">login</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <!-- FIXED: Added Script Logic for Password Visibility -->
    <script>
        const toggleBtn = document.getElementById('togglePassword');
        const passwordInput = document.getElementById('password');
        const icon = document.getElementById('toggleIcon');

        toggleBtn.addEventListener('click', () => {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            icon.innerText = type === 'password' ? 'visibility' : 'visibility_off';
        });
    </script>

    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        .toastify {
            padding: 12px 20px;
            border-radius: 8px;
            font-family: 'Manrope', sans-serif;
            font-weight: 600;
            font-size: 14px;
        }
        .toastify.success {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .toastify.error {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        }
    </style>
    <script>
        <% if (locals.flash && locals.flash.success && locals.flash.success.length > 0) { %>
        Toastify({
            text: "<%= locals.flash.success %>",
            duration: 3000,
            close: true,
            gravity: "top",
            position: "right",
            stopOnFocus: true,
            className: "success",
            style: {
                background: "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
            }
        }).showToast();
        <% } %>

        <% if (locals.flash && locals.flash.error && locals.flash.error.length > 0) { %>
        Toastify({
            text: "<%= locals.flash.error %>",
            duration: 3000,
            close: true,
            gravity: "top",
            position: "right",
            stopOnFocus: true,
            className: "error",
            style: {
                background: "linear-gradient(135deg, #f093fb 0%, #f5576c 100%)",
            }
        }).showToast();
        <% } %>
    </script>
</body>

</html>
<%- include('../header') %>

    <main class="flex-1 bg-background-light dark:bg-background-dark">
        <div class="max-w-7xl mx-auto px-6 py-10">

            <!-- PAGE HEADER -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8">
                <div>
                    <h1 class="text-3xl font-black tracking-tight text-charcoal dark:text-gray-100">
                        Admin Management
                    </h1>
                    <p class="text-gray-500 mt-1">
                        Directory of all authorized personnel with system-level access.
                    </p>
                </div>

                <!-- ADD ADMIN BUTTON -->
                <a href="/addAdminPage"
                    class="bg-primary hover:bg-primary/90 text-charcoal px-6 py-3 rounded-xl font-bold flex items-center gap-2 transition-all shadow-sm shadow-primary/30">
                    <span class="material-symbols-outlined">add_circle</span>
                    Add New Admin
                </a>
            </div>

            <!-- TABLE CARD -->
            <div
                class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden">

                <!-- SEARCH & ACTIONS -->
                <div
                    class="p-4 border-b border-gray-100 dark:border-gray-800 flex flex-wrap gap-4 items-center justify-between">
                    <div class="relative flex-1 max-w-md">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                            search
                        </span>
                        <input type="text" placeholder="Search by name, email or city..."
                            class="w-full pl-10 pr-4 py-2 bg-gray-50 dark:bg-gray-800 border-none rounded-lg text-sm focus:ring-2 focus:ring-primary/50" />
                    </div>

                    <div class="flex gap-2">
                        <button
                            class="p-2 text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors">
                            <span class="material-symbols-outlined">filter_list</span>
                        </button>
                    </div>
                </div>

                <!-- TABLE -->
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr
                                class="bg-gray-50/50 dark:bg-gray-800/50 text-xs uppercase tracking-widest text-gray-400 font-bold">
                                <th class="px-6 py-4 border-b">Profile</th>
                                <th class="px-6 py-4 border-b">Email Address</th>
                                <th class="px-6 py-4 border-b">Contact</th>
                                <th class="px-6 py-4 border-b">About</th>
                                <th class="px-6 py-4 border-b">City</th>
                                <th class="px-6 py-4 border-b">Gender</th>
                                <% if(admin.id==="6978ce786f8284b26d743e23" ) {%>
                                    <th class="px-6 py-4 border-b text-right">Actions</th>
                                    <% }%>

                            </tr>
                        </thead>

                        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">

                            <% allAdmin.forEach(subAdmin=> { %>
                                <tr class="hover:bg-gray-50/80 dark:hover:bg-gray-800/40 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <img src="/<%= subAdmin.profile_image %>" alt="Profile"
                                                class="w-10 h-10 rounded-full object-cover border border-gray-200" />

                                            <span class="text-sm font-bold">
                                                <%= subAdmin.fname %>
                                                    <%= subAdmin.lname %>
                                            </span>
                                        </div>
                                    </td>

                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        <%= subAdmin.email %>
                                    </td>

                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        <%= subAdmin.phone %>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        <%= subAdmin.about %>
                                    </td>


                                    <td class="px-6 py-4 text-sm text-gray-600">
                                        <%= subAdmin.city %>
                                    </td>

                                    <td class="px-6 py-4">
                                        <span
                                            class="px-2.5 py-1 bg-blue-50 text-blue-600 text-[10px] font-bold rounded-md">
                                            <%= subAdmin.gender %>
                                        </span>
                                    </td>

                                    <% if(admin.id==="6978ce786f8284b26d743e23" ) {%>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex justify-end gap-2">
                                                <a href="/editAdmin/<%= subAdmin._id %>"
                                                    class="p-2 hover:bg-gray-100 rounded-lg">
                                                    <span class="material-symbols-outlined">edit</span>
                                                </a>

                                                <a href="/deleteAdmin?adminId=<%= subAdmin._id %>"
                                                    class="p-2 hover:bg-red-50 hover:text-red-500 rounded-lg">
                                                    <span class="material-symbols-outlined">delete</span>
                                                </a>
                                            </div>
                                        </td>
                                        <% }%>
                                </tr>
                                <% }) %>

                        </tbody>

                    </table>
                </div>
            </div>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.all.min.js"></script>
    <script>
        if (<%= locals.flash.success !== "" && locals.flash.success.length > 0 %>) {
            Swal.fire({
                title: "Success!",
                text: "<%= locals.flash.success %>",
                icon: "success"
            });
        }
        if (<%= locals.flash.error !== "" && locals.flash.error.length > 0 %>) {
            Swal.fire({
                title: "Error!",
                text: "<%= locals.flash.error %>",
                icon: "error"
            });
        }
    </script>
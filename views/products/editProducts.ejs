<%- include('../header') %>
    <main class="flex-1 p-6 md:px-10 pb-10 flex justify-center bg-gray-50/50 dark:bg-[#0B0F1A]">
        <div
            class="bg-white dark:bg-gray-900 w-full max-w-2xl rounded-[2.5rem] shadow-xl border border-gray-100 dark:border-gray-800 p-8 md:p-12 mt-10">

            <div class="mb-10 text-center">
                <h2 class="text-3xl font-black text-slate-800 dark:text-white uppercase tracking-tighter">Edit Product
                </h2>
                <p class="text-slate-500 text-sm mt-2">Modify the details for this product item</p>
            </div>

            <!-- ACTION URL UPDATED -->
            <form action="/products/updateProducts/<%= singleProduct._id %>" method="POST" enctype="multipart/form-data">

                <!-- IMAGE PREVIEW -->
                <div class="flex flex-col items-center justify-center">
                    <div class="relative group">
                        <div
                            class="w-40 h-40 rounded-3xl border-4 border-primary/30 dark:border-gray-700 flex items-center justify-center bg-gray-50 dark:bg-gray-800 overflow-hidden shadow-inner">
                            <img id="imagePreview" src="/<%= singleProduct.productImage %>"
                                class="w-full h-full object-cover" />
                        </div>
                        <label
                            class="absolute -bottom-4 -right-4 bg-primary text-charcoal p-4 rounded-2xl shadow-xl cursor-pointer hover:scale-110 transition-all">
                            <span class="material-symbols-outlined">photo_camera</span>
                            <input type="file" name="productImage" class="hidden" accept="image/*"
                                onchange="previewImage(event)" />
                        </label>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- 1. MAIN CATEGORY -->
                    <div class="space-y-2">
                        <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-2">Main
                            Category</label>
                        <select name="category_id" id="category_id" onchange="fetchSubCategories()"
                            class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-none outline-none font-bold text-slate-700 dark:text-gray-200"
                            required>
                            <% allCategory.forEach((category)=> { %>
                                <option value="<%= category._id %>"
                                    <%=singleProduct.category_id.toString()==category._id.toString() ? 'selected' : ''
                                    %>>
                                    <%= category.categoryName %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <!-- 2. SUB-CATEGORY -->
                    <div class="space-y-2">
                        <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-2">Sub
                            Category</label>
                        <select name="subCategory_id" id="subCategory_id" onchange="fetchExtraCategories()"
                            class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-none outline-none font-bold text-slate-700 dark:text-gray-200"
                            required>
                            <% allSubCategory.forEach((sub)=> { %>
                                <option value="<%= sub._id %>"
                                    <%=singleProduct.subCategory_id.toString()==sub._id.toString() ? 'selected' : '' %>>
                                    <%= sub.subCategoryName %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <!-- 3. EXTRA CATEGORY (Added Missing Level 3) -->
                    <div class="space-y-2 md:col-span-2">
                        <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-2">Extra
                            Category</label>
                        <select name="extraCategory_id" id="extraCategory_id"
                            class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-none outline-none font-bold text-slate-700 dark:text-gray-200"
                            required>
                            <% allExtraCategory.forEach((extra)=> { %>
                                <option value="<%= extra._id %>"
                                    <%=singleProduct.extraCategory_id.toString()==extra._id.toString() ? 'selected' : ''
                                    %>>
                                    <%= extra.extraCategoryName %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <!-- 4. PRODUCT NAME -->
                    <div class="space-y-2 md:col-span-2">
                        <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-2">Product
                            Name</label>
                        <input name="productName" value="<%= singleProduct.productName %>" type="text"
                            class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-none outline-none font-bold text-slate-700 dark:text-gray-200"
                            required />
                    </div>

                    <!-- 5. PRICE FIELDS -->
                    <div class="space-y-2">
                        <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-2">Current
                            Price</label>
                        <input name="productPrice" value="<%= singleProduct.productPrice %>" type="text"
                            class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-none outline-none font-bold text-slate-700 dark:text-gray-200"
                            required />
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-2">Old
                            Price</label>
                        <input name="productOldPrice" value="<%= singleProduct.productOldPrice %>" type="text"
                            class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-none outline-none font-bold text-slate-700 dark:text-gray-200"
                            required />
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-2">Stock</label>
                        <input name="productStock" value="<%= singleProduct.productStock %>" type="text"
                            class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-none outline-none font-bold text-slate-700 dark:text-gray-200"
                            required />
                    </div>

                    <!-- 6. DESCRIPTION -->
                    <div class="space-y-2 md:col-span-2">
                        <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-2">Product
                            Description</label>
                        <textarea name="productDescription" rows="3"
                            class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-none outline-none font-bold text-slate-700 dark:text-gray-200"
                            required><%= singleProduct.productDescription %></textarea>
                    </div>
                </div>

                <!-- ACTIONS -->
                <div class="flex items-center justify-end gap-6 pt-6">
                    <a href="/products/viewProducts"
                        class="text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-slate-900 transition-colors">Cancel</a>
                    <button type="submit"
                        class="px-12 py-4 bg-primary text-charcoal font-black rounded-2xl shadow-lg shadow-primary/30 hover:scale-105 transition-all uppercase tracking-widest text-sm">
                        Update Product
                    </button>
                </div>
            </form>
        </div>
    </main>

    <script>
        function previewImage(event) {
            if (event.target.files[0]) {
                document.getElementById('imagePreview').src = URL.createObjectURL(event.target.files[0]);
            }
        }

        async function fetchSubCategories() {
            const catId = document.getElementById('category_id').value;
            const subDropdown = document.getElementById('subCategory_id');
            const extraDropdown = document.getElementById('extraCategory_id');

            subDropdown.innerHTML = '<option value="">Loading...</option>';
            extraDropdown.innerHTML = '<option value="">Select Sub Category First</option>';

            try {
                const response = await fetch(`/extraCategory/getSubCategories/${catId}`);
                const subs = await response.json();
                subDropdown.innerHTML = '<option value="">Select Sub Category</option>';
                subs.forEach(sub => {
                    subDropdown.innerHTML += `<option value="${sub._id}">${sub.subCategoryName}</option>`;
                });
            } catch (err) {
                subDropdown.innerHTML = '<option value="">Error</option>';
            }
        }

        async function fetchExtraCategories() {
            const subId = document.getElementById('subCategory_id').value;
            const extraDropdown = document.getElementById('extraCategory_id');
            extraDropdown.innerHTML = '<option value="">Loading...</option>';

            try {
                const response = await fetch(`/products/getExtraCategories/${subId}`);
                const extras = await response.json();
                extraDropdown.innerHTML = '<option value="">Select Extra Category</option>';
                extras.forEach(extra => {
                    extraDropdown.innerHTML += `<option value="${extra._id}">${extra.extraCategoryName}</option>`;
                });
            } catch (err) {
                extraDropdown.innerHTML = '<option value="">Error</option>';
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.all.min.js"></script>
    <script>
        <% if (locals.flash && locals.flash.success && locals.flash.success.length > 0) { %>
        Swal.fire({
            title: "Success!",
            text: "<%= locals.flash.success %>",
            icon: "success"
        });
        <% } %>

        <% if (locals.flash && locals.flash.error && locals.flash.error.length > 0) { %>
        Swal.fire({
            title: "Error!",
            text: "<%= locals.flash.error %>",
            icon: "error"
        });
        <% } %>
    </script>
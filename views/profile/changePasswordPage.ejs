<%- include('../header') %>

    <main class="flex-1 p-6 md:p-10 flex justify-center">
        <div
            class="bg-white dark:bg-gray-900 w-full max-w-2xl rounded-3xl shadow-xl border border-gray-100 dark:border-gray-800 p-8 md:p-12 self-start">

            <div class="mb-10 text-center">
                <div class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-charcoal dark:text-primary text-3xl">lock_reset</span>
                </div>
                <h2 class="text-3xl font-bold dark:text-white uppercase tracking-tight">Change Password</h2>
                <p class="text-gray-500 text-sm mt-2">Ensure your account is using a long, random password to stay
                    secure.</p>
            </div>

            <form action="/change-password" method="POST" class="space-y-6">

                <!-- Current Password -->
                <div class="space-y-2">
                    <label class="text-xs font-bold uppercase tracking-wider text-charcoal/60 px-1">
                        Current Password
                    </label>
                    <div class="relative">
                        <input type="password" name="current_psw"
                            class="w-full px-6 py-4 rounded-full bg-gray-50 dark:bg-gray-800 border-none outline-none focus:ring-2 focus:ring-primary/50 dark:text-white"
                            placeholder="Enter current password" required />
                    </div>
                </div>

                <!-- New Password -->
                <div class="space-y-2">
                    <label class="text-xs font-bold uppercase tracking-wider text-charcoal/60 px-1">
                        New Password
                    </label>
                    <div class="relative">
                        <input type="password" name="new_psw"
                            class="w-full px-6 py-4 rounded-full bg-gray-50 dark:bg-gray-800 border-none outline-none focus:ring-2 focus:ring-primary/50 dark:text-white"
                            placeholder="Enter new password" required />
                    </div>
                </div>

                <!-- Confirm New Password -->
                <div class="space-y-2">
                    <label class="text-xs font-bold uppercase tracking-wider text-charcoal/60 px-1">
                        Confirm New Password
                    </label>
                    <div class="relative">
                        <input type="password" name="confirm_psw"
                            class="w-full px-6 py-4 rounded-full bg-gray-50 dark:bg-gray-800 border-none outline-none focus:ring-2 focus:ring-primary/50 dark:text-white"
                            placeholder="Confirm new password" required />
                    </div>
                </div>

                <div
                    class="pt-6 border-t border-gray-100 dark:border-gray-800 flex flex-col sm:flex-row gap-4 justify-end">
                    <a href="/profile"
                        class="px-8 py-4 text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-charcoal transition-colors text-center">
                        Cancel
                    </a>
                    <button type="submit"
                        class="px-12 py-4 bg-primary text-charcoal font-bold rounded-full shadow-xl shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all uppercase tracking-widest text-sm">
                        Update Password
                    </button>
                </div>

            </form>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.all.min.js"></script>
    <script>
        if (<%= locals.flash.success !== "" && locals.flash.success.length > 0 %>) {
            Swal.fire({
                title: "Success!",
                text: "<%= locals.flash.success %>",
                icon: "success"
            });
        }
        if (<%= locals.flash.error !== "" && locals.flash.error.length > 0 %>) {
            Swal.fire({
                title: "Error!",
                text: "<%= locals.flash.error %>",
                icon: "error"
            });
        }
    </script>
<%- include('../header') %>
    <main class="flex-1 p-6 md:px-10 pb-10 flex justify-center bg-gray-50/50 dark:bg-[#0B0F1A]">
        <div
            class="bg-white dark:bg-gray-900 w-full max-w-2xl rounded-[2.5rem] shadow-xl border border-gray-100 dark:border-gray-800 p-8 md:p-12 self-start mt-10">

            <div class="mb-10 text-center">
                <h2 class="text-3xl font-black text-slate-800 dark:text-white uppercase tracking-tighter">Add Extra
                    Category</h2>
            </div>

            <form class="space-y-6" action="/extraCategory/addExtraCategory" method="POST"
                enctype="multipart/form-data">
                <!-- Image Upload -->
                <div class="flex flex-col items-center mb-6">
                    <div class="relative group">
                        <div
                            class="w-32 h-32 rounded-3xl border-4 border-dashed border-primary/30 flex items-center justify-center bg-gray-50 dark:bg-gray-800 overflow-hidden">
                            <img id="imagePreview" class="hidden w-full h-full object-cover" />
                            <span id="defaultIcon"
                                class="material-symbols-outlined text-4xl text-gray-300">add_photo_alternate</span>
                        </div>
                        <label class="absolute -bottom-2 -right-2 bg-primary p-3 rounded-xl cursor-pointer shadow-lg">
                            <input type="file" name="extraCategoryImage" class="hidden" onchange="previewImage(event)"
                                required />
                            <span class="material-symbols-outlined text-sm">edit</span>
                        </label>
                    </div>
                </div>

                <div class="grid grid-cols-1 gap-5">
                    <!-- 1. Category Selection -->
                    <div class="space-y-1">
                        <label class="text-[10px] font-black uppercase text-slate-400 ml-2">Main Category</label>
                        <select name="category_id" id="category_id" onchange="fetchSubCategories()"
                            class="w-full px-5 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-none font-bold text-slate-700 dark:text-gray-200"
                            required>
                            <option value="">Select Category</option>
                            <% allCategory.forEach(cat=> { %>
                                <option value="<%= cat._id %>">
                                    <%= cat.categoryName %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <!-- 2. Sub Category Selection (Dynamic) -->
                    <div class="space-y-1">
                        <label class="text-[10px] font-black uppercase text-slate-400 ml-2">Sub Category</label>
                        <select name="subCategory_id" id="subCategory_id"
                            class="w-full px-5 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-none font-bold text-slate-700 dark:text-gray-200"
                            required>
                            <option value="">Select Category First</option>
                        </select>
                    </div>

                    <div class="space-y-1">
                        <label class="text-[10px] font-black uppercase text-slate-400 ml-2">Extra Category Name</label>
                        <input name="extraCategoryName" type="text"
                            class="w-full px-5 py-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-none font-bold text-slate-700 dark:text-gray-200"
                            placeholder="e.g. Men's Running Shoes" required />
                    </div>
                </div>

                <div class="flex items-center justify-end gap-4 pt-6">
                    <a href="/extraCategory/viewExtraCategory"
                        class="text-xs font-bold text-slate-400 uppercase">Cancel</a>
                    <button type="submit"
                        class="px-8 py-4 bg-primary text-charcoal font-black rounded-2xl shadow-lg shadow-primary/20 hover:scale-105 transition-all text-sm uppercase">Add
                        Category</button>
                </div>
            </form>
        </div>
    </main>

    <script>
        // Preview Image
        function previewImage(event) {
            const preview = document.getElementById('imagePreview');
            preview.src = URL.createObjectURL(event.target.files[0]);
            preview.classList.remove('hidden');
            document.getElementById('defaultIcon').classList.add('hidden');
        }

        async function fetchSubCategories() {
            const catId = document.getElementById('category_id').value;
            const subDropdown = document.getElementById('subCategory_id');

            subDropdown.innerHTML = '<option value="">Loading...</option>';

            if (!catId) return subDropdown.innerHTML = '<option value="">Select Category First</option>';

            try {
                const response = await fetch(`/extraCategory/getSubCategories/${catId}`);
                const subs = await response.json();

                subDropdown.innerHTML = '<option value="">Select Sub Category</option>';
                subs.forEach(sub => {
                    subDropdown.innerHTML += `<option value="${sub._id}">${sub.subCategoryName}</option>`;
                });
            } catch (err) {
                subDropdown.innerHTML = '<option value="">Error loading</option>';
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.all.min.js"></script>
    <script>
        <% if (locals.flash && locals.flash.success && locals.flash.success.length > 0) { %>
        Swal.fire({
            title: "Success!",
            text: "<%= locals.flash.success %>",
            icon: "success"
        });
        <% } %>

        <% if (locals.flash && locals.flash.error && locals.flash.error.length > 0) { %>
        Swal.fire({
            title: "Error!",
            text: "<%= locals.flash.error %>",
            icon: "error"
        });
        <% } %>
    </script>
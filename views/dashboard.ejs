<%- include('header') %>

    <div class="grid grid-cols-12 gap-6">

        <!-- Welcome Card -->
        <div
            class="col-span-12 lg:col-span-8 relative overflow-hidden bg-primary/20 dark:bg-primary/10 rounded-3xl p-8 md:p-12 flex flex-col md:flex-row items-center justify-between group">
            <div class="relative z-10 max-w-md">
                <span
                    class="inline-block px-3 py-1 bg-white/50 dark:bg-black/20 rounded-full text-xs font-bold uppercase tracking-wider mb-4">
                    Daily Update
                </span>
                <!-- FIXED: Made greeting dynamic using the admin object from controller -->
                <h2 class="text-4xl font-bold mb-4 dark:text-white">
                    Good morning, <%= admin.fname %>!
                </h2>
                <p class="text-charcoal/80 dark:text-gray-300 text-lg mb-8">
                    You have 12 active projects and 3 pending notifications to review today. Keep it up!
                </p>
                <div class="flex gap-4">
                    <button
                        class="px-6 py-3 bg-charcoal dark:bg-white text-white dark:text-charcoal font-semibold rounded-xl hover:scale-105 transition-transform shadow-lg shadow-charcoal/20">
                        Check Schedule
                    </button>
                    <button
                        class="px-6 py-3 bg-white/40 dark:bg-gray-800/40 backdrop-blur font-semibold rounded-xl hover:bg-white/60 transition-colors border border-white/20">
                        Manage Wallet
                    </button>
                </div>
            </div>

            <div class="relative mt-8 md:mt-0">
                <div class="absolute -inset-4 bg-primary/30 rounded-full blur-3xl animate-pulse"></div>
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBh-UHbozf0-fyu8YXJPATpaE8mQGJMMsagijo5us-Z0aqtw0YodGoB5r2Cit7roUjGs8OT-sjH9PN1dyykljGHUoADCuzcWTBUtinjcXm0KHorR-94X4j5-5J8kCdc4qStHZWHonUgWmr6dRLuGg4tZ7iTQPLPuWih_7hc63f5qpUwd132WcDxIikPonsKrN9LspeRuejKOiRfT6MQWTYcx52ItyNqBQVN5GXTjrzGJZ3fpWCHppXWB6AKhmcEYLlzLtdZkTdx9M0"
                    alt="Abstract Illustration"
                    class="w-64 h-64 object-cover rounded-2xl shadow-2xl relative z-10 transform -rotate-3 group-hover:rotate-0 transition-transform duration-500" />
            </div>
        </div>

        <!-- Notifications -->
        <div
            class="col-span-12 lg:col-span-4 bg-white dark:bg-gray-900 rounded-3xl p-6 shadow-sm flex flex-col border border-transparent hover:border-primary/20 transition-all relative">
            <div class="absolute top-6 right-6">
                <button
                    class="p-1.5 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg text-gray-300 hover:text-primary">
                    <span class="material-symbols-outlined text-lg">edit</span>
                </button>
            </div>

            <h3 class="text-xl font-bold mb-6 dark:text-white">Notifications</h3>

            <div class="space-y-4">
                <div class="p-4 bg-primary/10 rounded-2xl border-l-4 border-primary flex items-start gap-4">
                    <span class="material-icons-round text-primary">add_task</span>
                    <div>
                        <p class="text-sm font-semibold dark:text-white">New project added</p>
                        <p class="text-xs text-gray-500">Recently added with no deadline yet.</p>
                    </div>
                </div>

                <div
                    class="p-4 bg-red-50 dark:bg-red-900/10 rounded-2xl border-l-4 border-red-400 flex items-start gap-4">
                    <span class="material-icons-round text-red-400">payments</span>
                    <div>
                        <p class="text-sm font-semibold dark:text-white">Refund requested</p>
                        <p class="text-xs text-gray-500">Project owner Adam requested a refund.</p>
                    </div>
                </div>

                <div
                    class="p-4 bg-blue-50 dark:bg-blue-900/10 rounded-2xl border-l-4 border-blue-400 flex items-start gap-4">
                    <span class="material-icons-round text-blue-400">cake</span>
                    <div>
                        <p class="text-sm font-semibold dark:text-white">Tatia's Anniversary</p>
                        <p class="text-xs text-gray-500">Today marks 2 years with the team!</p>
                    </div>
                </div>
            </div>

            <button
                class="mt-6 py-3 w-full border-2 border-dashed border-gray-200 dark:border-gray-800 rounded-2xl text-sm font-medium text-gray-400 hover:border-primary hover:text-primary">
                + Add Reminder
            </button>
        </div>

        <!-- 5-Box Metric Row -->
        <div class="col-span-12">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">

                <!-- 1. Total Categories -->
                <div
                    class="bg-white dark:bg-gray-900 p-6 rounded-3xl shadow-sm border border-transparent hover:border-primary/20 transition-all">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="material-icons-round text-primary text-sm">category</span>
                        <p class="text-gray-500 dark:text-gray-400 text-xs font-bold uppercase tracking-wider">
                            Categories</p>
                    </div>
                    <h4 class="text-3xl font-bold dark:text-white">
                        <%= categoryCount %>
                    </h4>
                </div>

                <!-- 2. Sub Categories -->
                <div
                    class="bg-white dark:bg-gray-900 p-6 rounded-3xl shadow-sm border border-transparent hover:border-primary/20 transition-all">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="material-icons-round text-blue-400 text-sm">account_tree</span>
                        <p class="text-gray-500 dark:text-gray-400 text-xs font-bold uppercase tracking-wider">Sub Categories
                        </p>
                    </div>
                    <h4 class="text-3xl font-bold dark:text-white">
                        <%= subCategoryCount %>
                    </h4>
                </div>

                <!-- 3. Extra Categories -->
                <div
                    class="bg-white dark:bg-gray-900 p-6 rounded-3xl shadow-sm border border-transparent hover:border-primary/20 transition-all">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="material-icons-round text-purple-400 text-sm">layers</span>
                        <p class="text-gray-500 dark:text-gray-400 text-xs font-bold uppercase tracking-wider">Extra Categories</p>
                    </div>
                    <h4 class="text-3xl font-bold dark:text-white">
                        <%= extraCategoryCount %>
                    </h4>
                </div>

                <!-- 4. Total Products -->
                <div
                    class="bg-white dark:bg-gray-900 p-6 rounded-3xl shadow-sm border border-transparent hover:border-primary/20 transition-all">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="material-icons-round text-emerald-400 text-sm">inventory_2</span>
                        <p class="text-gray-500 dark:text-gray-400 text-xs font-bold uppercase tracking-wider">Products
                        </p>
                    </div>
                    <h4 class="text-3xl font-bold dark:text-white">
                        <%= productCount %>
                    </h4>
                </div>

                <!-- 5. Active admins -->
                <div
                    class="bg-white dark:bg-gray-900 p-6 rounded-3xl shadow-sm border border-transparent hover:border-primary/20 transition-all">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="material-icons-round text-amber-400 text-sm">bolt</span>
                        <p class="text-gray-500 dark:text-gray-400 text-xs font-bold uppercase tracking-wider">Admins</p>
                    </div>
                    <h4 class="text-3xl font-bold dark:text-white">
                        <%= adminCount %>
                    </h4>
                </div>

            </div>
        </div>

        <!-- Team Performance -->
        <div class="col-span-12 lg:col-span-8 bg-white dark:bg-gray-900 rounded-3xl p-8 shadow-sm">
            <h3 class="text-xl font-bold dark:text-white mb-6">Team Performance</h3>
            <div class="h-64 flex items-end gap-4">
                <div class="w-full bg-primary h-[40%] rounded-t-xl"></div>
                <div class="w-full bg-primary h-[70%] rounded-t-xl"></div>
                <div class="w-full bg-primary h-[55%] rounded-t-xl"></div>
                <div class="w-full bg-primary h-[90%] rounded-t-xl"></div>
                <div class="w-full bg-primary h-[45%] rounded-t-xl"></div>
                <div class="w-full bg-primary h-[75%] rounded-t-xl"></div>
                <div class="w-full bg-primary h-[60%] rounded-t-xl"></div>
            </div>
        </div>

        <!-- Active Projects -->
        <div class="col-span-12 lg:col-span-4 bg-white dark:bg-gray-900 rounded-3xl p-8 shadow-sm">
            <h3 class="text-xl font-bold mb-6 dark:text-white">Active Projects</h3>

            <div class="space-y-6">
                <div>
                    <p class="font-semibold dark:text-white">Mobile UI Design</p>
                    <div class="w-full bg-gray-200 h-2 rounded-full mt-2">
                        <div class="bg-primary h-full w-[75%] rounded-full"></div>
                    </div>
                </div>

                <div>
                    <p class="font-semibold dark:text-white">Dashboard API</p>
                    <div class="w-full bg-gray-200 h-2 rounded-full mt-2">
                        <div class="bg-green-400 h-full w-[40%] rounded-full"></div>
                    </div>
                </div>

                <div>
                    <p class="font-semibold dark:text-white">Brand Marketing</p>
                    <div class="w-full bg-gray-200 h-2 rounded-full mt-2">
                        <div class="bg-amber-400 h-full w-[92%] rounded-full"></div>
                    </div>
                </div>
            </div>

            <button class="mt-8 w-full py-3 bg-charcoal text-white rounded-xl">
                Create New Project
            </button>
        </div>

    </div>
    <!-- FIXED: This closes the <main> tag opened in header.ejs -->
    </main>


    <footer class="bg-background-light dark:bg-background-dark/50 px-6 md:px-10 py-6 mt-auto">
        <div
            class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-charcoal/80 dark:text-gray-500">
            <p>© 2024 Lumina Admin. All rights reserved.</p>
            <div class="flex items-center gap-6">
                <a href="#" class="hover:text-primary transition-colors">Privacy Policy</a>
                <a href="#" class="hover:text-primary transition-colors">Terms of Service</a>
                <a href="#" class="hover:text-primary transition-colors">Support</a>
            </div>
        </div>
    </footer>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.all.min.js"></script>
    <script>
        if (<%= locals.flash.success !== "" && locals.flash.success.length > 0 %>) {
            Swal.fire({
                title: "Success!",
                text: "<%= locals.flash.success %>",
                icon: "success"
            });
        }
        if (<%= locals.flash.error !== "" && locals.flash.error.length > 0 %>) {
            Swal.fire({
                title: "Error!",
                text: "<%= locals.flash.error %>",
                icon: "error"
            });
        }
    </script>

    </body>

    </html>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Lumina Admin Panel</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,container-queries"></script>

    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.min.css" rel="stylesheet">

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#F7CBCA",
                        "background-light": "#F1F7F7",
                        "background-dark": "#1A202C",
                        charcoal: "#5D6B6B",
                        "muted-gray": "#D5E5E5",
                    },
                    fontFamily: {
                        display: ["Outfit", "sans-serif"],
                        sans: ["Outfit", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "1rem",
                        xl: "1.5rem",
                        "2xl": "2.5rem",
                    },
                },
            },
        };
    </script>

    <style type="text/tailwindcss">
        @layer base {
            body {
                font-family: 'Outfit', sans-serif;
            }
        }

        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
        }

        .dark .glass {
            background: rgba(26, 32, 44, 0.7);
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
         summary::-webkit-details-marker { display: none; }

    /* --- Theme Active State --- */
    .active-link {
        background-color: rgba(247, 203, 202, 0.15) !important; /* Soft version of #f7cbca */
        color: #f7cbca !important;
    }
    
    /* Ensure icon in active link also takes theme color */
    .active-link .material-icons-round {
        color: #f7cbca !important;
    }

    .active-sub-link {
        color: #f7cbca !important;
        font-weight: 600;
    }

    /* Active Dot styling */
    .active-sub-link .dot {
        background-color: #f7cbca !important;
        box-shadow: 0 0 0 4px rgba(247, 203, 202, 0.2); 
    }

    /* Custom Scrollbar for Sidebar */
    #sidebar-nav::-webkit-scrollbar { width: 4px; }
    #sidebar-nav::-webkit-scrollbar-thumb { background: #f7cbca; border-radius: 10px; }
    </style>
</head>

<body
    class="bg-background-light dark:bg-background-dark text-charcoal dark:text-gray-200 transition-colors duration-300 min-h-screen flex">

    <!-- Sidebar -->
    <aside
        class="w-20 md:w-[17rem] bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 flex flex-col items-center md:items-stretch py-8 px-4 shrink-0">

        <div class="flex items-center gap-3 px-2 mb-10">
            <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shadow-lg shadow-primary/20">
                <span class="material-icons-round text-white">bubble_chart</span>
            </div>
            <span class="text-xl font-bold hidden md:block tracking-tight dark:text-white">Lumina.</span>
        </div>

        <nav id="sidebar-nav"
            class="flex-1 space-y-1 px-3 py-4 bg-white dark:bg-gray-900 h-screen w-64 border-r border-gray-200 dark:border-gray-800">

            <!-- Dashboard -->
            <a href="/dashboard"
                class="nav-link flex items-center gap-4 px-4 py-3 text-gray-500 hover:bg-[#f7cbca]/10 hover:text-[#f7cbca] rounded-xl transition-all group">
                <span class="material-icons-round group-hover:text-[#f7cbca]">dashboard</span>
                <span class="font-medium">Dashboard</span>
            </a>

            <!-- Admin Management -->
            <details class="group outline-none">
                <summary
                    class="flex items-center justify-between cursor-pointer list-none px-4 py-3 text-gray-500 hover:bg-[#f7cbca]/10 hover:text-[#f7cbca] rounded-xl transition-all">
                    <div class="flex items-center gap-4">
                        <span class="material-icons-round">manage_accounts</span>
                        <span class="font-medium">Admins</span>
                    </div>
                    <span
                        class="material-icons-round text-sm transition-transform group-open:rotate-180">expand_more</span>
                </summary>
                <div class="mt-1 ml-6 flex flex-col border-l-2 border-gray-100 dark:border-gray-700">
                    <a href="/addAdminPage"
                        class="nav-sub-link relative flex items-center py-2 pl-6 text-sm text-gray-500 hover:text-[#f7cbca] transition-colors">
                        <span class="dot absolute left-0 w-2 h-2 -ml-[5px] rounded-full bg-gray-200"></span>
                        Add Admin
                    </a>
                    <a href="/viewAdminPage"
                        class="nav-sub-link relative flex items-center py-2 pl-6 text-sm text-gray-500 hover:text-[#f7cbca] transition-colors">
                        <span class="dot absolute left-0 w-2 h-2 -ml-[5px] rounded-full bg-gray-200"></span>
                        All Admins
                    </a>
                </div>
            </details>

            <!-- Categories -->
            <details class="group outline-none">
                <summary
                    class="flex items-center justify-between cursor-pointer list-none px-4 py-3 text-gray-500 hover:bg-[#f7cbca]/10 hover:text-[#f7cbca] rounded-xl transition-all">
                    <div class="flex items-center gap-4">
                        <span class="material-icons-round">category</span>
                        <span class="font-medium">Categories</span>
                    </div>
                    <span
                        class="material-icons-round text-sm transition-transform group-open:rotate-180">expand_more</span>
                </summary>
                <div class="mt-1 ml-6 flex flex-col border-l-2 border-gray-100 dark:border-gray-700">
                    <a href="/category/addCategoryPage"
                        class="nav-sub-link relative flex items-center py-2 pl-6 text-sm text-gray-500 hover:text-[#f7cbca] transition-colors">
                        <span class="dot absolute left-0 w-2 h-2 -ml-[5px] rounded-full bg-gray-200"></span>
                        Add Category
                    </a>
                    <a href="/category/viewCategory"
                        class="nav-sub-link relative flex items-center py-2 pl-6 text-sm text-gray-500 hover:text-[#f7cbca] transition-colors">
                        <span class="dot absolute left-0 w-2 h-2 -ml-[5px] rounded-full bg-gray-200"></span>
                        View Categories
                    </a>
                </div>
            </details>

            <!-- Sub-Categories -->
            <details class="group outline-none">
                <summary
                    class="flex items-center justify-between cursor-pointer list-none px-4 py-3 text-gray-500 hover:bg-[#f7cbca]/10 hover:text-[#f7cbca] rounded-xl transition-all">
                    <div class="flex items-center gap-4">
                        <span class="material-icons-round">layers</span>
                        <span class="font-medium">Sub-Categories</span>
                    </div>
                    <span
                        class="material-icons-round text-sm transition-transform group-open:rotate-180">expand_more</span>
                </summary>
                <div class="mt-1 ml-6 flex flex-col border-l-2 border-gray-100 dark:border-gray-700">
                    <a href="/subCategory/addSubCategoryPage"
                        class="nav-sub-link relative flex items-center py-2 pl-6 text-sm text-gray-500 hover:text-[#f7cbca] transition-colors">
                        <span class="dot absolute left-0 w-2 h-2 -ml-[5px] rounded-full bg-gray-200"></span>
                        Add Sub-Category
                    </a>
                    <a href="/subCategory/viewSubCategory"
                        class="nav-sub-link relative flex items-center py-2 pl-6 text-sm text-gray-500 hover:text-[#f7cbca] transition-colors">
                        <span class="dot absolute left-0 w-2 h-2 -ml-[5px] rounded-full bg-gray-200"></span>
                        View Sub-Categories
                    </a>
                </div>
            </details>

            <!-- Extra Categories -->
            <details class="group outline-none">
                <summary
                    class="flex items-center justify-between cursor-pointer list-none px-4 py-3 text-gray-500 hover:bg-[#f7cbca]/10 hover:text-[#f7cbca] rounded-xl transition-all">
                    <div class="flex items-center gap-4">
                        <span class="material-icons-round">extension</span>
                        <span class="font-medium">Extra-Categories</span>
                    </div>
                    <span
                        class="material-icons-round text-sm transition-transform group-open:rotate-180">expand_more</span>
                </summary>
                <div class="mt-1 ml-6 flex flex-col border-l-2 border-gray-100 dark:border-gray-700">
                    <a href="/extraCategory/addExtraCategoryPage"
                        class="nav-sub-link relative flex items-center py-2 pl-6 text-sm text-gray-500 hover:text-[#f7cbca] transition-colors">
                        <span class="dot absolute left-0 w-2 h-2 -ml-[5px] rounded-full bg-gray-200"></span>
                        Add Extra Category
                    </a>
                    <a href="/extraCategory/viewExtraCategory"
                        class="nav-sub-link relative flex items-center py-2 pl-6 text-sm text-gray-500 hover:text-[#f7cbca] transition-colors">
                        <span class="dot absolute left-0 w-2 h-2 -ml-[5px] rounded-full bg-gray-200"></span>
                        View Extra Category
                    </a>
                </div>
            </details>

            <!-- All Products -->
            <details class="group outline-none">
                <summary
                    class="flex items-center justify-between cursor-pointer list-none px-4 py-3 text-gray-500 hover:bg-[#f7cbca]/10 hover:text-[#f7cbca] rounded-xl transition-all">
                    <div class="flex items-center gap-4">
                        <!-- ICON CHANGED FROM 'extension' TO 'inventory_2' -->
                        <span class="material-icons-round">inventory_2</span>
                        <span class="font-medium">Products</span>
                    </div>
                    <span
                        class="material-icons-round text-sm transition-transform group-open:rotate-180">expand_more</span>
                </summary>
                <div class="mt-1 ml-6 flex flex-col border-l-2 border-gray-100 dark:border-gray-700">
                    <a href="/products/addProductsPage"
                        class="nav-sub-link relative flex items-center py-2 pl-6 text-sm text-gray-500 hover:text-[#f7cbca] transition-colors">
                        <span class="dot absolute left-0 w-2 h-2 -ml-[5px] rounded-full bg-gray-200"></span>
                        Add Products
                    </a>
                    <a href="/products/viewProducts"
                        class="nav-sub-link relative flex items-center py-2 pl-6 text-sm text-gray-500 hover:text-[#f7cbca] transition-colors">
                        <span class="dot absolute left-0 w-2 h-2 -ml-[5px] rounded-full bg-gray-200"></span>
                        View Products
                    </a>
                </div>
            </details>
        </nav>
    </aside>

    <!-- Main wrapper -->
    <div class="flex-1 flex flex-col min-h-screen">

        <main class="flex-1 p-6 md:p-10">
            <header class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">

                <div>
                    <h1 class="text-3xl font-bold dark:text-white uppercase tracking-tight">
                        Admin Panel
                    </h1>
                </div>

                <div class="flex items-center gap-4">

                    <div class="relative hidden lg:block">
                        <span
                            class="material-icons-round absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">search</span>
                        <input type="text"
                            class="pl-10 pr-4 py-2.5 bg-white dark:bg-gray-900 rounded-xl w-64 shadow-sm focus:ring-2 focus:ring-primary border-none outline-none"
                            placeholder="Search anything..." />
                    </div>

                    <!-- Profile Wrapper -->
                    <div class="relative">

                        <!-- Profile Toggle -->
                        <div id="profileToggle"
                            class="flex items-center gap-3 bg-white dark:bg-gray-900 p-1.5 pr-4 rounded-2xl shadow-sm cursor-pointer select-none border border-gray-100 dark:border-gray-800">

                            <img src="/<%= admin.profile_image %>" class="w-10 h-10 rounded-xl object-cover" />

                            <div class="hidden md:block">
                                <p class="text-sm font-semibold dark:text-white">
                                    <%= admin.fname %>
                                        <%= admin.lname %>
                                </p>
                                <p class="text-xs text-gray-500">Administrator</p>
                            </div>
                            <span class="material-icons-round text-gray-400">expand_more</span>
                        </div>

                        <!-- Dropdown -->
                        <div id="profileDropdown"
                            class="hidden absolute right-0 mt-3 w-56 bg-white dark:bg-gray-900 rounded-2xl shadow-xl border border-gray-100 dark:border-gray-800 z-50 overflow-hidden">

                            <div class="p-4 border-b border-gray-100 dark:border-gray-800">
                                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">
                                    Profile Actions
                                </p>
                            </div>

                            <div class="p-2">
                                <!-- Fixed Profile Link -->
                                <a href="/profile"
                                    class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-charcoal dark:text-gray-300 hover:bg-primary/10 rounded-xl transition-colors">
                                    <span class="material-symbols-outlined text-gray-400">account_circle</span>
                                    View Profile
                                </a>

                                <a href="/change-password"
                                    class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-charcoal dark:text-gray-300 hover:bg-primary/10 rounded-xl transition-colors">
                                    <span class="material-symbols-outlined text-gray-400">settings</span>
                                    Change Password
                                </a>

                                <hr class="my-2 border-gray-100 dark:border-gray-800" />

                                <a href="/logout"
                                    class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10 rounded-xl transition-colors">
                                    <span class="material-symbols-outlined">logout</span>
                                    Logout
                                </a>
                            </div>
                        </div>

                    </div>
                </div>

            </header>

            <script>
                // Dropdown Toggle Logic
                const toggle = document.getElementById('profileToggle');
                const dropdown = document.getElementById('profileDropdown');

                if (toggle && dropdown) {
                    toggle.addEventListener('click', (e) => {
                        e.stopPropagation();
                        dropdown.classList.toggle('hidden');
                    });

                    document.addEventListener('click', () => {
                        dropdown.classList.add('hidden');
                    });
                }
            </script>

            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    // Get the current URL path
                    const currentPath = window.location.pathname;
                    const navLinks = document.querySelectorAll(".nav-link, .nav-sub-link");

                    navLinks.forEach(link => {
                        if (link.getAttribute("href") === currentPath) {
                            // Style the active item
                            if (link.classList.contains("nav-link")) {
                                link.classList.add("active-link");
                            }

                            if (link.classList.contains("nav-sub-link")) {
                                link.classList.add("active-sub-link");

                                // Automatically open the parent <details>
                                const parentDetails = link.closest("details");
                                if (parentDetails) {
                                    parentDetails.open = true;
                                    // Color the parent text and icon when child is active
                                    const summary = parentDetails.querySelector('summary');
                                    summary.style.color = "#f7cbca";
                                    summary.querySelector('.material-icons-round').style.color = "#f7cbca";
                                }
                            }
                        }
                    });
                });
            </script>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Lumina Admin Panel</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,container-queries"></script>

    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.min.css" rel="stylesheet">

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#F7CBCA",
                        "background-light": "#F1F7F7",
                        "background-dark": "#1A202C",
                        charcoal: "#5D6B6B",
                        "muted-gray": "#D5E5E5",
                    },
                    fontFamily: {
                        display: ["Outfit", "sans-serif"],
                        sans: ["Outfit", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "1rem",
                        xl: "1.5rem",
                        "2xl": "2.5rem",
                    },
                },
            },
        };
    </script>

    <style type="text/tailwindcss">
        @layer base {
            body {
                font-family: 'Outfit', sans-serif;
            }
        }

        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
        }

        .dark .glass {
            background: rgba(26, 32, 44, 0.7);
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>

<body
    class="bg-background-light dark:bg-background-dark text-charcoal dark:text-gray-200 transition-colors duration-300 min-h-screen flex">

    <!-- Sidebar -->
    <aside
        class="w-20 md:w-64 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 flex flex-col items-center md:items-stretch py-8 px-4 shrink-0">

        <div class="flex items-center gap-3 px-2 mb-10">
            <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shadow-lg shadow-primary/20">
                <span class="material-icons-round text-white">bubble_chart</span>
            </div>
            <span class="text-xl font-bold hidden md:block tracking-tight dark:text-white">Lumina.</span>
        </div>

        <nav class="flex-1 space-y-2">
            <!-- Fixed Dashboard Link -->
            <a href="/dashboard"
                class="flex items-center gap-4 px-4 py-3 bg-primary/10 text-charcoal dark:text-primary rounded-xl transition-all">
                <span class="material-icons-round">grid_view</span>
                <span class="font-medium hidden md:block">Dashboard</span>
            </a>
            <a href="/addAdminPage"
                class="flex items-center gap-4 px-4 py-3 text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 rounded-xl transition-all">
                <span class="material-icons-round">person_add</span>
                <span class="font-medium hidden md:block">Add Admin</span>
            </a>
            <a href="/viewAdminPage"
                class="flex items-center gap-4 px-4 py-3 text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 rounded-xl transition-all">
                <span class="material-icons-round">assignment</span>
                <span class="font-medium hidden md:block">All Admins</span>
            </a>
        </nav>

    </aside>

    <!-- Main wrapper -->
    <div class="flex-1 flex flex-col min-h-screen">

        <main class="flex-1 p-6 md:p-10">
            <header class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">

                <div>
                    <h1 class="text-3xl font-bold dark:text-white uppercase tracking-tight">
                        Admin Panel
                    </h1>
                </div>

                <div class="flex items-center gap-4">

                    <div class="relative hidden lg:block">
                        <span
                            class="material-icons-round absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">search</span>
                        <input type="text"
                            class="pl-10 pr-4 py-2.5 bg-white dark:bg-gray-900 rounded-xl w-64 shadow-sm focus:ring-2 focus:ring-primary border-none outline-none"
                            placeholder="Search anything..." />
                    </div>

                    <!-- Profile Wrapper -->
                    <div class="relative">

                        <!-- Profile Toggle -->
                        <div id="profileToggle"
                            class="flex items-center gap-3 bg-white dark:bg-gray-900 p-1.5 pr-4 rounded-2xl shadow-sm cursor-pointer select-none border border-gray-100 dark:border-gray-800">

                            <!-- FIXED: Use the dynamic admin image from the controller -->
                            <img src="/<%= admin.profile_image %>" class="w-10 h-10 rounded-xl object-cover" />

                            <div class="hidden md:block">
                                <p class="text-sm font-semibold dark:text-white">
                                    <%= admin.fname %>
                                        <%= admin.lname %>
                                </p>
                                <p class="text-xs text-gray-500">Administrator</p>
                            </div>
                            <span class="material-icons-round text-gray-400">expand_more</span>
                        </div>

                        <!-- Dropdown -->
                        <div id="profileDropdown"
                            class="hidden absolute right-0 mt-3 w-56 bg-white dark:bg-gray-900 rounded-2xl shadow-xl border border-gray-100 dark:border-gray-800 z-50 overflow-hidden">

                            <div class="p-4 border-b border-gray-100 dark:border-gray-800">
                                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">
                                    Profile Actions
                                </p>
                            </div>

                            <div class="p-2">
                                <!-- Fixed Profile Link -->
                                <a href="/profile"
                                    class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-charcoal dark:text-gray-300 hover:bg-primary/10 rounded-xl transition-colors">
                                    <span class="material-symbols-outlined text-gray-400">account_circle</span>
                                    View Profile
                                </a>

                                <a href="/change-password"
                                    class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-charcoal dark:text-gray-300 hover:bg-primary/10 rounded-xl transition-colors">
                                    <span class="material-symbols-outlined text-gray-400">settings</span>
                                    Change Password
                                </a>

                                <hr class="my-2 border-gray-100 dark:border-gray-800" />

                                <a href="/logout"
                                    class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10 rounded-xl transition-colors">
                                    <span class="material-symbols-outlined">logout</span>
                                    Logout
                                </a>
                            </div>
                        </div>

                    </div>
                </div>

            </header>

            <script>
                // Dropdown Toggle Logic
                const toggle = document.getElementById('profileToggle');
                const dropdown = document.getElementById('profileDropdown');

                if (toggle && dropdown) {
                    toggle.addEventListener('click', (e) => {
                        e.stopPropagation();
                        dropdown.classList.toggle('hidden');
                    });

                    document.addEventListener('click', () => {
                        dropdown.classList.add('hidden');
                    });
                }
            </script>
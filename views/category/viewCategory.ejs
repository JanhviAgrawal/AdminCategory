<%- include('../header') %>

    <main class="min-h-screen bg-gray-50/50 dark:bg-[#0B0F1A] pb-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">

            <!-- PAGE HEADER -->
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
                <div>
                    <h1 class="text-4xl font-black tracking-tight text-slate-900 dark:text-white">
                        Category <span class="text-primary">Hub</span>
                    </h1>
                   
                </div>

                <a href="/category/addCategoryPage"
                    class="group bg-primary hover:bg-primary/90 text-charcoal px-8 py-4 rounded-2xl font-bold flex items-center gap-3 transition-all shadow-lg shadow-primary/20 hover:shadow-primary/40 active:scale-95">
                    <span class="material-symbols-outlined transition-transform group-hover:rotate-90">add</span>
                    Create New Category
                </a>
            </div>

            <!-- CATEGORY GRID -->
            <% if (allCategory && allCategory.length> 0) { %>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                    <% allCategory.forEach(category=> { %>
                        <div
                            class="group relative bg-white dark:bg-gray-900 rounded-[2rem] border border-gray-100 dark:border-gray-800 overflow-hidden transition-all duration-300 hover:shadow-2xl hover:shadow-primary/10 hover:-translate-y-2">

                            <!-- IMAGE CONTAINER (Larger & Aspect Ratio controlled) -->
                            <div class="relative aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-gray-800">
                                <img src="/<%= category.categoryImage %>" alt="<%= category.categoryName %>"
                                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />

                                <!-- Overlay Gradient -->
                                <div
                                    class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                </div>

                                <!-- Quick Action Floating Buttons -->
                                <div
                                    class="absolute top-4 right-4 flex flex-col gap-2 translate-x-12 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300">
                                    <a href="/category/editCategory/<%= category._id %>"
                                        class="p-3 bg-white/90 backdrop-blur-md hover:bg-white text-slate-800 rounded-xl shadow-xl transition-colors">
                                        <span class="material-symbols-outlined text-xl">edit</span>
                                    </a>
                                    <button onclick="confirmDelete('<%= category._id %>')"
                                        class="p-3 bg-red-500/90 backdrop-blur-md hover:bg-red-600 text-white rounded-xl shadow-xl transition-colors">
                                        <span class="material-symbols-outlined text-xl">delete</span>
                                    </button>
                                </div>
                            </div>

                            <!-- CONTENT -->
                            <div class="p-6">
                                <div class="flex items-center justify-between mb-2">
                                    <h3 class="text-xl font-bold text-slate-800 dark:text-white truncate">
                                        <%= category.categoryName %>
                                    </h3>
                                </div>
                            </div>

                            <!-- BOTTOM DECORATION LINE -->
                            <div class="h-1.5 w-0 bg-primary group-hover:w-full transition-all duration-500"></div>
                        </div>
                        <% }) %>
                </div>
                <% } else { %>
                    <!-- EMPTY STATE -->
                    <div
                        class="flex flex-col items-center justify-center py-20 bg-white dark:bg-gray-900 rounded-[3rem] border-2 border-dashed border-gray-200 dark:border-gray-800">
                        <div
                            class="w-24 h-24 bg-gray-50 dark:bg-gray-800 rounded-full flex items-center justify-center mb-6">
                            <span class="material-symbols-outlined text-5xl text-gray-300">category</span>
                        </div>
                        <h3 class="text-2xl font-bold text-slate-800 dark:text-white">No categories found</h3>
                        <p class="text-slate-500 mt-2">Start by creating your very first category.</p>
                    </div>
                    <% } %>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.all.min.js"></script>
    <script>
        // Modern Delete Confirmation
        function confirmDelete(id) {
            Swal.fire({
                title: "Are you sure?",
                text: "This category will be permanently removed.",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#EF4444",
                cancelButtonColor: "#64748B",
                confirmButtonText: "Yes, delete it!",
                background: document.documentElement.classList.contains('dark') ? '#111827' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#fff' : '#000'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `/category/deleteCategory/${id}`;
                }
            });
        }

    <% if (locals.flash && locals.flash.success && locals.flash.success.length > 0) { %>
            Swal.fire({
                title: "Success!",
                text: "<%= locals.flash.success %>",
                icon: "success",
                timer: 3000,
                showConfirmButton: false
            });
    <% } %>

    <% if (locals.flash && locals.flash.error && locals.flash.error.length > 0) { %>
            Swal.fire({
                title: "Error!",
                text: "<%= locals.flash.error %>",
                icon: "error"
            });
    <% } %>
    </script>
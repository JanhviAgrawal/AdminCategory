<%- include('../header') %>
    <main class="min-h-screen bg-gray-50/50 dark:bg-[#0B0F1A] pb-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">
            <!-- HEADER -->
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
                <div>
                    <h1 class="text-4xl font-black tracking-tight text-slate-900 dark:text-white">Sub <span
                            class="text-primary">Categories</span></h1>
                </div>
                <a href="/subCategory/addSubCategoryPage"
                    class="bg-primary text-charcoal px-8 py-4 rounded-2xl font-bold flex items-center gap-3 transition-all shadow-lg shadow-primary/20 hover:scale-105">
                    <span class="material-symbols-outlined">add</span> Create Sub Category
                </a>
            </div>

            <!-- GRID -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                <% allSubCategory.forEach(sub=> { %>
                    <div
                        class="group bg-white dark:bg-gray-900 rounded-[2rem] border border-gray-100 dark:border-gray-800 overflow-hidden transition-all duration-300 hover:shadow-2xl hover:-translate-y-2">
                        <div class="relative aspect-[4/3] overflow-hidden">
                            <img src="/<%= sub.subCategoryImage %>"
                                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60">
                            </div>

                            <!-- Floating Parent Tag -->
                            <div
                                class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-lg text-[10px] font-black uppercase text-slate-800">
                                <%= sub.category_id ? sub.category_id.categoryName : 'Uncategorized' %>
                            </div>

                            <!-- Actions -->
                            <div
                                class="absolute top-4 right-4 flex flex-col gap-2 translate-x-12 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300">
                                <a href="/subCategory/editSubCategory/<%= sub._id %>"
                                    class="p-3 bg-white text-slate-800 rounded-xl shadow-xl hover:bg-primary transition-colors">
                                    <span class="material-symbols-outlined">edit</span>
                                </a>
                                <button onclick="confirmDelete('<%= sub._id %>')"
                                    class="p-3 bg-red-500 text-white rounded-xl shadow-xl hover:bg-red-600 transition-colors">
                                    <span class="material-symbols-outlined">delete</span>
                                </button>
                            </div>
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold text-slate-800 dark:text-white truncate">
                                <%= sub.subCategoryName %>
                            </h3>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: "Delete Sub-Category?",
                text: "This cannot be undone!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#EF4444",
                confirmButtonText: "Yes, delete it!"
            }).then((result) => {
                if (result.isConfirmed) window.location.href = `/subCategory/deleteSubCategory/${id}`;
            });
        }

        <% if (locals.flash && locals.flash.success && locals.flash.success.length > 0) { %>
        Swal.fire({
            title: "Success!",
            text: "<%= locals.flash.success %>",
            icon: "success",
            timer: 3000,
            showConfirmButton: false
        });
        <% } %>

        <% if (locals.flash && locals.flash.error && locals.flash.error.length > 0) { %>
        Swal.fire({
            title: "Error!",
            text: "<%= locals.flash.error %>",
            icon: "error"
        });
        <% } %>
    </script>